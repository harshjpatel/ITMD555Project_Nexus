<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Handle/Decoration -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#E5E7EB"
            app:cardCornerRadius="2dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp" />

        <!-- Profile Image Container -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/profileImage"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:background="#F3F4FF"
                android:padding="12dp"
                android:src="@drawable/ic_launcher_foreground"
                app:shapeAppearanceOverlay="@style/CircleAppearance"
                app:strokeColor="#6C7BFF"
                app:strokeWidth="3dp" />

            <!-- Online Status Indicator (Circle) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="6dp"
                app:cardBackgroundColor="#10B981"
                app:cardCornerRadius="9dp"
                app:cardElevation="2dp"
                app:strokeColor="@android:color/white"
                app:strokeWidth="2dp" />
        </FrameLayout>

        <TextView
            android:id="@+id/profileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-medium"
            android:text="Email ID"
            android:textColor="#111827"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/profileEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif"
            android:text="email@example.com"
            android:textColor="#6B7280"
            android:textSize="14sp" />

        <!-- Stats Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#F9FAFB"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MEMBER"
                        android:textColor="#9CA3AF"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Free Tier"
                        android:textColor="#374151"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:layout_marginVertical="4dp"
                    android:background="#E5E7EB"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="JOINED"
                        android:textColor="#9CA3AF"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Jan 2024"
                        android:textColor="#374151"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShowFCMToken"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:text="Show FCM Token"
            android:textColor="#10B981"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#ECFDF5"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_dialog_info"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconSize="20dp"
            app:iconTint="#10B981"
            app:rippleColor="#D1FAE5" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRefreshWidget"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:text="Refresh Widget"
            android:textColor="#6C7BFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#F3F4FF"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_menu_rotate"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconSize="20dp"
            app:iconTint="#6C7BFF"
            app:rippleColor="#E5E7EB" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="Log Out"
            android:textColor="#EF4444"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#FEF2F2"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_lock_power_off"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconSize="20dp"
            app:iconTint="#EF4444"
            app:rippleColor="#FEE2E2" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>