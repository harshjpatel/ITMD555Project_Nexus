<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="8dp">

    <!-- Thread Line -->
    <View
        android:id="@+id/threadLine"
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="12dp"
        android:layout_marginStart="4dp"
        android:background="@color/comment_line" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivCommentUser"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_launcher_foreground"
                android:background="#E0E7FF"
                app:shapeAppearanceOverlay="@style/CircleAppearance" />

            <TextView
                android:id="@+id/tvCommentUser"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="u/UserHandle"
                android:textColor="@color/titleText"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCommentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="1h"
                android:textColor="@color/subtitleText"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvCommentText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
            android:textColor="@color/inputText"
            android:textSize="14sp"
            android:lineSpacingExtra="2dp" />

        <!-- Comment Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/ivCommentUpvote"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/arrow_up_float"
                app:tint="@color/subtitleText" />

            <TextView
                android:id="@+id/tvCommentUpvotes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="12sp"
                android:textColor="@color/subtitleText"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="12dp" />

            <ImageView
                android:id="@+id/ivCommentDownvote"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/arrow_down_float"
                app:tint="@color/subtitleText" />

            <TextView
                android:id="@+id/tvCommentDownvotes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="12sp"
                android:textColor="@color/subtitleText"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/tvCommentReply"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reply"
                android:textSize="12sp"
                android:textColor="@color/subtitleText"
                android:layout_marginStart="16dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </LinearLayout>
</LinearLayout>