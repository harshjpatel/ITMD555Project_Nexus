<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Community Chip -->
    <TextView
        android:id="@+id/widgetCommunityName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_community_tag"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:text="COMMUNITY"
        android:textColor="#6C7BFF"
        android:textSize="10sp"
        android:textStyle="bold" />

    <!-- Post Title -->
    <TextView
        android:id="@+id/widgetPostTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:text="Post Title"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Post Content Summary -->
    <TextView
        android:id="@+id/widgetPostContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:lineSpacingExtra="3dp"
        android:maxLines="3"
        android:text="Post content preview..."
        android:textColor="#A0AABF"
        android:textSize="13sp" />

    <!-- Horizontal Divider -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="12dp"
        android:background="#2A3350" />

    <!-- Engagement Stats Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Upvotes -->
        <ImageView
            android:id="@+id/widgetUpvoteIcon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@android:drawable/arrow_up_float"
            android:contentDescription="Upvotes" />

        <TextView
            android:id="@+id/widgetUpvoteCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="0"
            android:textColor="#A0AABF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Downvotes -->
        <ImageView
            android:id="@+id/widgetDownvoteIcon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="16dp"
            android:src="@android:drawable/arrow_down_float"
            android:contentDescription="Downvotes" />

        <TextView
            android:id="@+id/widgetDownvoteCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="0"
            android:textColor="#A0AABF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Comments -->
        <ImageView
            android:id="@+id/widgetCommentIcon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@android:drawable/stat_notify_chat"
            android:contentDescription="Comments" />

        <TextView
            android:id="@+id/widgetCommentCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="0"
            android:textColor="#A0AABF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Bookmarks -->
        <ImageView
            android:id="@+id/widgetBookmarkIcon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="16dp"
            android:src="@drawable/ic_bookmark"
            android:contentDescription="Bookmarks" />

        <TextView
            android:id="@+id/widgetBookmarkCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="0"
            android:textColor="#A0AABF"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>
</LinearLayout>